<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Reset Your Password</title>
</head>
<body style="margin: 0; padding: 0; background-color: #111827; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;">
    <table role="presentation" width="100%" cellspacing="0" cellpadding="0" style="min-height: 100vh;">
        <tr>
            <td align="center" style="padding: 40px 16px;">
                <table role="presentation" width="100%" cellspacing="0" cellpadding="0" style="max-width: 480px; background-color: #1f2937; border-radius: 16px; border: 1px solid #374151; overflow: hidden;">
                    <!-- Header -->
                    <tr>
                        <td style="background: linear-gradient(135deg, #dc2626 0%, #ef4444 100%); padding: 32px 32px 28px; text-align: center;">
                            <div style="font-size: 32px; margin-bottom: 8px;">🔒</div>
                            <h1 style="margin: 0; color: #ffffff; font-size: 22px; font-weight: 700; letter-spacing: -0.3px;">
                                Password Reset
                            </h1>
                        </td>
                    </tr>

                    <!-- Body -->
                    <tr>
                        <td style="padding: 32px;">
                            <p style="margin: 0 0 8px; color: #f9fafb; font-size: 16px; font-weight: 600;">
                                Reset your password
                            </p>
                            <p style="margin: 0 0 24px; color: #9ca3af; font-size: 14px; line-height: 1.6;">
                                We received a request to reset the password for your Cotton account. Enter this code in the app to set a new password:
                            </p>

                            <!-- Code -->
                            <div style="background-color: #111827; border: 1px solid #374151; border-radius: 12px; padding: 20px; text-align: center; margin-bottom: 24px;">
                                <span style="font-size: 36px; font-weight: 700; letter-spacing: 8px; color: #fca5a5; font-family: 'SF Mono', 'Fira Code', monospace;">
                                    {{code}}
                                </span>
                            </div>

                            <!-- Warning -->
                            <table role="presentation" width="100%" cellspacing="0" cellpadding="0" style="margin-bottom: 24px;">
                                <tr>
                                    <td style="padding: 12px 16px; background-color: rgba(239, 68, 68, 0.1); border-radius: 8px; border-left: 3px solid #ef4444;">
                                        <p style="margin: 0; color: #fca5a5; font-size: 13px; line-height: 1.5;">
                                            ⏱ This code expires in <strong style="color: #fecaca;">2 hours</strong>
                                        </p>
                                    </td>
                                </tr>
                            </table>

                            <!-- Security notice -->
                            <table role="presentation" width="100%" cellspacing="0" cellpadding="0" style="margin-bottom: 24px;">
                                <tr>
                                    <td style="padding: 12px 16px; background-color: rgba(245, 158, 11, 0.08); border-radius: 8px; border-left: 3px solid #f59e0b;">
                                        <p style="margin: 0; color: #fbbf24; font-size: 13px; line-height: 1.5;">
                                            ⚠️ If you didn't request this reset, your account may be at risk. Please change your password immediately and contact support.
                                        </p>
                                    </td>
                                </tr>
                            </table>

                            <p style="margin: 0; color: #6b7280; font-size: 13px; line-height: 1.5;">
                                Never share this code with anyone. Cotton will never ask for your code via phone or message.
                            </p>
                        </td>
                    </tr>

                    <!-- Footer -->
                    <tr>
                        <td style="padding: 20px 32px; border-top: 1px solid #374151; text-align: center;">
                            <p style="margin: 0; color: #4b5563; font-size: 12px;">
                                This is an automated message from Cotton · Please do not reply
                            </p>
                        </td>
                    </tr>
                </table>
            </td>
        </tr>
    </table>
</body>
</html>